# Cairn configuration template. Copy to `.env` and fill in. `make init` does this
# for you and generates CAIRN_SECRET_KEY. NEVER commit a real secret here.
#
# Env vars override any values set in the optional YAML overlay
# (config.example.yaml, loaded via CAIRN_CONFIG_FILE).

# ─── Core ────────────────────────────────────────────────────────────────────

# Auth mode: `single` (no login, one implicit user owns every corpus — the
# personal-install default) or `multi` (login required; admin provisions users
# and per-user read-only base mounts, data scoped per user).
CAIRN_AUTH_MODE=single

# Public hostname the reverse proxy (Traefik/Caddy) routes to.
CAIRN_HOSTNAME=cairn.example.com

# itsdangerous signing key for session cookies. The app refuses to start while
# this is empty or a known placeholder. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
CAIRN_SECRET_KEY=

# Async SQLAlchemy URL. SQLite (WAL) lives on the writable /app/data volume.
# Four slashes = absolute path: sqlite+aiosqlite:////app/data/cairn.db
CAIRN_DATABASE_URL=sqlite+aiosqlite:////app/data/cairn.db

# Directory for the parallel .ots proof store (writable volume, never the
# read-only corpus mounts).
CAIRN_PROOF_STORE_PATH=/app/proofs

# Run `alembic upgrade head` on startup. Set 0 to manage migrations manually
# (`make migrate`).
CAIRN_AUTO_MIGRATE=1

# ─── Scheduler ───────────────────────────────────────────────────────────────

# Run the in-process background scanner loop. Set 0 for cron-only deployments
# that drive `cairn scan --once` from system cron instead (/healthz freshness
# still works — it reads the `runs` table regardless of who writes it).
CAIRN_SCHEDULER_ENABLED=1

# Scheduler tick: how often (seconds) the loop wakes to scan due corpora.
CAIRN_SCAN_INTERVAL_SECONDS=30

# How often (seconds) the daily OTS upgrade pass runs across all corpora.
CAIRN_UPGRADE_INTERVAL_SECONDS=86400

# Floor (seconds) on each corpus's freshness window. A corpus is fresh if it
# has a successful run within max(2 × hash_cadence_seconds, this floor); the
# floor keeps fast-cadence corpora from flapping the /healthz dead-man's switch.
CAIRN_HEALTH_FRESHNESS_FLOOR_SECONDS=900

# ─── OpenTimestamps notary ───────────────────────────────────────────────────

# Verify backend: `explorer` (block-explorer lookup, works out of the box) or
# `node` (point at your own Bitcoin node for fully trustless verification).
CAIRN_VERIFY_BACKEND=explorer

# Block explorer used when CAIRN_VERIFY_BACKEND=explorer.
CAIRN_EXPLORER_URL=https://blockstream.info

# Comma-separated OTS calendar URLs. Leave empty to use the public calendar
# pools shipped with the `ots` client.
CAIRN_OTS_CALENDARS=

# Raise an alarm when a proof has stayed incomplete (not yet anchored to a
# confirmed Bitcoin block) for this many days — surfaces a stuck calendar.
CAIRN_INCOMPLETE_PROOF_ALARM_DAYS=7

# Max files stamped in a single `ots stamp` call. One calendar round-trip
# aggregates the batch's digests yet still yields one independent .ots per file,
# so a higher value means far fewer calendar requests (minutes, not days, for a
# large corpus). Bounded to keep argv length + the Merkle build sane.
CAIRN_OTS_STAMP_BATCH_SIZE=256

# ─── Notifications ───────────────────────────────────────────────────────────

# Email transport. SMTP is the implemented channel; `resend` / `ses` are
# recognized by the UI but not yet wired — selecting them raises a clear error.
CAIRN_EMAIL_PROVIDER=local

# SMTP server used to send alert email. These are now also editable from the
# panel (Settings → Notifications); anything saved there is stored in the DB and
# OVERRIDES the values below. The env vars act as the initial defaults / fallback,
# so an env-only deploy keeps working. Per-corpus recipients live in the corpus's
# alert routing (alert_json), set from the add/edit-corpus form.
# CAIRN_SMTP_HOST=smtp.example.com
CAIRN_SMTP_PORT=587
# Use STARTTLS on the connection (recommended for port 587).
CAIRN_SMTP_STARTTLS=1
# Optional SMTP auth. Leave blank for an unauthenticated relay.
# CAIRN_SMTP_USER=cairn@example.com
# Password: set here for an env-only deploy, or in the panel (stored in the DB).
# CAIRN_SMTP_PASSWORD=
# Envelope/From address on outgoing alert mail.
# CAIRN_SMTP_FROM=cairn@example.com

# ─── Host paths (used by docker-compose.yml, not the app) ────────────────────

# Image registry for `make push` / compose `image:`.
REGISTRY=localhost:5000

# Host paths for the writable volumes. `make init` creates these.
DATA_HOST_PATH=./data
PROOFS_HOST_PATH=./proofs
